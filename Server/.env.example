# Copy this file to .env and fill in your own values.
# NEVER commit the actual .env file!

PORT=5000

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gitcube?retryWrites=true&w=majority

# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth App credentials
# Create one at: https://gitlab.com/-/user_settings/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Jira (Atlassian) OAuth credentials
# Create one at: https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Trello credentials
TRELLO_CLIENT_ID=
TRELLO_CLIENT_SECRET=

# Hugging Face API token (optional, for AI features)
HF_TOKEN=

# AES-256 encryption key for storing OAuth tokens in DB
ENCRYPTION_KEY=your-random-32-character-secret-key
